# Database
DB__URL=sqlite:///data/db/bbbot.db
DB__ECHO=false

# MLB Stats API (no key required)
MLB_API__BASE_URL=https://statsapi.mlb.com/api/v1
MLB_API__TIMEOUT=30

# The Odds API (https://the-odds-api.com/)
ODDS_API__API_KEY=
ODDS_API__REGIONS=us
ODDS_API__MARKETS=h2h,totals,spreads

# Weather API (OpenWeatherMap or Visual Crossing)
WEATHER_API_KEY=

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Alerts
DISCORD_WEBHOOK_URL=

# Runtime
LOG_LEVEL=INFO
SEASON=2026
